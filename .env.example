# Copy to .env.testnet (gitignored) and fill in.

SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com

# Uniswap V4 PoolManager on Sepolia (canonical). Verify before deploying.
POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543

# Owner of the deployed hook. Use a fresh wallet for testnet; multisig for mainnet.
JITSHIELD_OWNER=0xYourOwnerAddress

# Deployer wallet. NEVER reuse mainnet keys here.
DEPLOYER_ADDRESS=0xYourDeployerAddress
DEPLOYER_PRIVATE_KEY=0xYourFreshPrivateKey

# Hook config knobs
JITSHIELD_SURGE_BIPS=7000
JITSHIELD_PROTOCOL_BIPS=1000
JITSHIELD_TIMELOCK_BLOCKS=5
