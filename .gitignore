# Compiler files
cache/
out/

# Commonly ignored directories
.logs/
.ignore/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# (Foundry's auto-generated `forge doc` output goes to docs/ by default, but we use
# docs/ as the GitHub Pages source for the landing page. We commit the static landing
# files explicitly; `forge doc` is not used.)

# Dotenv file
.env
.env.*
!.env.example

# Foundry
foundry.lock

# Editor
.vscode/
.idea/

# Local scripts used during scaffolding
check.sh
scaffold.sh
install_v4.sh
build.sh
test_run.sh
commit.sh
scripts/replay/finder.log

# --- Open-core: private detection kernel (NEVER commit) ----------------------
# The public engine ships the interface + reference scorer. The precise detector
# that closes GAP-1 (add-first JIT) stays on the operator's machine only.
engine/_core_signal.py
engine/.secret/
engine/**/__pycache__/
*.secret.py
private/

# --- Hygiene: dev scaffolding artefacts that must never ship --------------
# Root-level shell scripts used during scaffolding/deploy iteration. The
# already-explicit allow/deny rules above remain; the catch-all below ignores
# all the rest. scripts/replay/*.sh stays tracked because it lives in a
# subdirectory, which /*.sh does not match.
/*.sh

# Local IDE / agent state.
.claude/

# Archive bundles — never commit zipped repos.
*.zip
*.tar
*.tar.gz
*.tgz
